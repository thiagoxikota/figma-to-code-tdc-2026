{
  "name": "figma-to-code-tdc-2026",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "check:tokens": "node scripts/check-tokens.mjs",
    "validate:workshop": "npm run typecheck && node scripts/validate-takes.mjs",
    "workshop:start": "vite",
    "workshop:preview": "vite preview",
    "workshop:check": "npm run validate:workshop",
    "workshop:reset": "node scripts/reset.mjs",
    "workshop:doctor": "node scripts/doctor.mjs",
    "workshop:setup-mcp": "node scripts/mcp-config.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.7"
  }
}
